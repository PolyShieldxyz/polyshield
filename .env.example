# Vault signing EOA (never commit real key). This is the deposit-wallet OWNER: it derives the
# deposit wallet, signs relayer WALLET batches, and signs POLY_1271 CLOB orders.
VAULT_EOA_PRIVATE_KEY=

# Polymarket CLOB L2 HMAC credentials. Mint once with the operator EOA:
#   pnpm --filter @polyshield/signing-layer setup:deposit-wallet mint-creds
POLY_API_KEY=
POLY_SECRET=
POLY_PASSPHRASE=

# Polygon RPC (use a dedicated node or Alchemy/Infura endpoint)
POLYGON_RPC_URL=

# Deployed contract addresses (set after deployment)
VAULT_CONTRACT_ADDRESS=
SIGNING_LAYER_OPERATOR_ADDRESS=

# Proof Relay gas payer (separate EOA from signing EOA)
RELAYER_PRIVATE_KEY=

# Indexer
INDEXER_DB_PATH=./packages/backend/indexer/data/polyshield.db

# ── Production Polymarket integration ────────────────────────────────────────────────────
# CLOB + user-channel websocket. These default to production if unset; set them explicitly.
# DO NOT set MOCK_RELAYER_URL or DEPOSIT_WALLET_KEY in production — the executor selector
# prefers MOCK_RELAYER_URL and would silently route settlement to the mock relayer.
POLY_API_URL=https://clob.polymarket.com
POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user

# Polymarket builder relayer (gas-free deposit-wallet WALLET batches: deploy, approvals, redeem).
POLY_RELAYER_URL=

# Builder Program. POLY_BUILDER_CODE = on-chain order attribution (order.builder). The builder
# creds authenticate gas-free relayer batches. All optional; unset => non-builder path.
POLY_BUILDER_CODE=
POLY_BUILDER_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=
# Alternative to local builder creds: a remote builder signer.
# POLY_BUILDER_REMOTE_URL=
# POLY_BUILDER_REMOTE_TOKEN=

# Deposit wallet — derive with: setup:deposit-wallet derive-address. MUST equal the immutable
# Vault.depositWallet (set as DEPOSIT_WALLET at contract deploy).
DEPOSIT_WALLET_ADDRESS=

# Collateral + CTF (Polygon mainnet). VERIFY USDC_ADDRESS matches the token CollateralOnramp
# consumes / CollateralOfframp pays out before deploy — a mismatch breaks fundPolymarketWallet.
# USDC.e (bridged): 0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
USDC_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
PUSD_ADDRESS=0xC011a7E12a19f7B1f670d46F03B03f3342E82DFB
ONRAMP_ADDRESS=0x93070a847efEf7F70739046A929D47a521F5B8ee
OFFRAMP_ADDRESS=0x2957922Eb93268531d39fAcCA3B4dC5854
CTF_ADDRESS=0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
CTF_EXCHANGE_V2_ADDRESS=0xE111180000d2663C0091e4f400237545B87B996B
