{
  "name": "polyshield",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "circuits:test": "cd packages/circuits && nargo test",
    "circuits:compile": "cd packages/circuits && nargo compile",
    "circuits:deploy": "cd packages/circuits && nargo compile && cp target/bet_auth.json target/withdrawal.json target/settlement_credit.json target/bet_cancel.json target/cancel_credit.json ../frontend/public/circuits/",
    "circuits:verifiers": "bash packages/circuits/regen-verifiers.sh",
    "groth16:build": "cd packages/groth16 && npm run build",
    "groth16:test": "cd packages/groth16 && npm test",
    "groth16:generate": "cd packages/groth16 && npm run generate:all",
    "contracts:build": "cd packages/contracts && forge build",
    "contracts:test": "cd packages/contracts && forge test",
    "contracts:coverage": "cd packages/contracts && forge coverage",
    "dev:mock": "PATH=\"$HOME/.foundry/bin:$PATH\" sh -c 'cd packages/backend && node_modules/.bin/ts-node mock-env/src/index.ts'",
    "dev:frontend": "cd packages/frontend && node node_modules/next/dist/bin/next dev",
    "dev:all": "concurrently --names 'mock,frontend' --prefix-colors 'cyan,magenta' 'pnpm dev:mock' 'pnpm dev:frontend'"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
