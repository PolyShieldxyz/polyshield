{
  "name": "polyshield",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "circuits:compile": "cd Benchmarking/groth16 && pnpm compile:circuits",
    "circuits:setup": "cd Benchmarking/groth16 && pnpm setup:circuits",
    "circuits:verifiers": "cd Benchmarking/groth16 && pnpm generate:verifiers",
    "circuits:copy": "cd Benchmarking/groth16 && pnpm copy:artifacts",
    "circuits:fixtures": "cd Benchmarking/groth16 && pnpm generate:test-proofs",
    "circuits:all": "pnpm circuits:compile && pnpm circuits:setup && pnpm circuits:verifiers && pnpm circuits:copy && pnpm circuits:fixtures",
    "circuits:spec:check": "cd packages/circuits/Noir && nargo check",
    "contracts:build": "cd packages/contracts && forge build",
    "contracts:test": "cd packages/contracts && forge test",
    "contracts:coverage": "cd packages/contracts && forge coverage",
    "dev:mock": "PATH=\"$HOME/.foundry/bin:$PATH\" sh -c 'cd packages/backend && node_modules/.bin/ts-node mock-env/src/index.ts'",
    "dev:frontend": "cd packages/frontend && node node_modules/next/dist/bin/next dev",
    "dev:all": "concurrently --names 'mock,frontend' --prefix-colors 'cyan,magenta' 'pnpm dev:mock' 'pnpm dev:frontend'"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
