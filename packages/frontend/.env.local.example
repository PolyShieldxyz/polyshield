NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# Polygon mainnet read RPC.
# PRODUCTION: set the SERVER-ONLY var below (no NEXT_PUBLIC_ prefix). Browser reads are proxied
# through /api/rpc so the metered key is NEVER shipped in the client bundle and frontend traffic can
# be attributed/capped separately from the backend services. Use a DISTINCT key from the backend.
POLYGON_RPC_URL=https://your-provider/polygon/<server-only-key>
# DEV ONLY (optional): direct public RPC used when NEXT_PUBLIC_DEV_MODE=true. Leave unset in prod —
# any value here ships to the browser. Do NOT put a metered key in this var for a production deploy.
# NEXT_PUBLIC_POLYGON_RPC=https://polygon-rpc.com
