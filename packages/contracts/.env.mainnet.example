# ─────────────────────────────────────────────────────────────────────────────
# Polyshield — Polygon mainnet deploy env (Phase 4)
#
# Copy to a file the deploy operator controls (e.g. .env.mainnet) and `source` it
# before running the scripts. THIS FILE CONTAINS NO PRIVATE KEY — the deployer key
# lives in an encrypted Foundry keystore (`cast wallet import deployer`) and is
# supplied at broadcast time via `--account deployer`. Never put a raw key here.
# ─────────────────────────────────────────────────────────────────────────────

# ── RPC + verification ───────────────────────────────────────────────────────
# Use a private RPC (Alchemy/Infura/QuickNode) for reliability, or a public one. Verified
# working (chain-id 137): https://polygon-bor-rpc.publicnode.com  https://1rpc.io/matic
# Others commonly fine: https://polygon-rpc.com  https://rpc.ankr.com/polygon
# Test before deploying:  cast chain-id --rpc-url $POLYGON_RPC_URL   # must print 137
export POLYGON_RPC_URL="https://polygon-bor-rpc.publicnode.com"
export ETHERSCAN_API_KEY="<etherscan-v2-api-key>"          # one key verifies Polygon via Etherscan v2

# ── Signer (encrypted keystore; key NEVER stored here) ───────────────────────
# Create once:  cast wallet import deployer --interactive   (paste key, set a password)
# The PUBLIC address of that keystore account, passed as --sender:
export DEPLOYER_ADDRESS="0x<deployer-eoa-public-address>"

# ── Ownership / roles ────────────────────────────────────────────────────────
# For THIS test deploy: OWNER_ADDRESS == DEPLOYER_ADDRESS (single EOA owns + signs).
# ⚠ This means one hot key can instantly upgrade any contract — fine for a throwaway
#   small-cap test, NOT for the real launch (use a Gnosis Safe there).
export OWNER_ADDRESS="0x<owner-eoa-public-address>"
export SIGNING_LAYER_OPERATOR="0x<operator-eoa>"           # signs FC-9 attestations + Polymarket orders; == backend SIGNING_LAYER_OPERATOR_ADDRESS
# ⚠ DEPOSIT_WALLET is IMMUTABLE in the Vault (set once in initialize(), no setter). It MUST equal
#   the Polymarket builder-relayer-derived deposit wallet for your operator account —
#   `deriveDepositWalletAddress()` (signing-layer/depositWalletExecutor.ts) against POLY_RELAYER_URL.
#   Same value as the backend's DEPOSIT_WALLET_ADDRESS (the signing layer asserts they match at
#   startup). A wrong value here = JIT-funded pUSD sent to a wallet you don't control + a full
#   redeploy to fix. Get it from the Polymarket/signing-layer setup — do NOT invent it.
export DEPOSIT_WALLET="0x<relayer-derived-deposit-wallet>"

# ── External Polygon mainnet contracts — CONFIRM each before broadcasting ─────
# ⚠ Polymarket collateral is BRIDGED USDC.e, not Circle native USDC. Use the token
#   Polymarket settles in:
#     USDC.e (bridged, Polymarket): 0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
#     USDC   (native Circle):       0x3c499c542cEF5E3811e1192ce70d8cc03d5c3359
export USDC_ADDRESS="0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174"
# Polymarket ConditionalTokens Framework (CTF):
export CTF_ADDRESS="0x4D97DCd97eC945f40cF65F87097ACe5EA0476045"
# pUSD on/offramp — POLYMARKET-ECOSYSTEM contracts (CTF Exchange V2 / pUSD, the Apr-2026
# deposit-wallet model). You do NOT deploy these — use Polymarket's deployed addresses.
# onramp = USDC->pUSD, offramp = pUSD->USDC. ⚠ CONFIRM both against Polymarket's official
# addresses before broadcast: the offramp value in ICollateralOfframp.sol is TRUNCATED, and
# the USDC variant / pUSD spender are open verification items (coordinate with the backend
# Polymarket-integration work).
export ONRAMP_ADDRESS="0x93070a847efEf7F70739046A929D47a521F5B8ee"   # PolygonScan: Permissionless Collateral Onramp (USDC.e->pUSD)
export OFFRAMP_ADDRESS="0x2957922Eb93258b93368531d39fAcCA3B4dC5854"   # PolygonScan: Collateral Offramp (pUSD->USDC.e), verified 2026-06-07

# ── Filled in as you go ──────────────────────────────────────────────────────
export POSEIDON_T3_ADDRESS=""    # ← from STEP 0 (DeployPoseidon) output
export VAULT_ADDRESS=""          # ← from STEP 1 (Deploy) output

# ── Post-deploy governance ───────────────────────────────────────────────────
# SEC-007 cap on USDC deployed to Polymarket, in 6-decimal base units.
# e.g. 1000000000 = $1,000
export DEPLOYMENT_CAP="1000000000"
