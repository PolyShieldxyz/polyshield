    function test_gasBench_Honk_betCancel() public {
        bytes memory proof = _reformatHonkProof(
            vm.readFileBinary(string.concat(BENCH, "bet_cancel_honk_5.proof")), 5);
        bool ok = honk_bet_cancel.verify(proof, _betCancelInputs());
        assertTrue(ok, "Honk bet_cancel verify failed");
    }

    function test_gasBench_Honk_cancelCredit() public {
        bytes memory proof = _reformatHonkProof(
            vm.readFileBinary(string.concat(BENCH, "cancel_credit_honk_5.proof")), 6);
        bool ok = honk_cancel_credit.verify(proof, _cancelCreditInputs());
        assertTrue(ok, "Honk cancel_credit verify failed");
    }
}
