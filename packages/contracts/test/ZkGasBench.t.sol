pragma solidity ^0.8.24;

import {Test, console2} from "forge-std/Test.sol";

// UltraPLONK verifiers (generated by: nargo codegen-verifier)
import {BetAuthVerifier as BetAuthPlonk}             from "../src/verifiers/BetAuthVerifier.sol";
import {SettlementCreditVerifier as SettlementPlonk} from "../src/verifiers/SettlementCreditVerifier.sol";
import {WithdrawalVerifier as WithdrawalPlonk}       from "../src/verifiers/WithdrawalVerifier.sol";
import {BetCancelVerifier as BetCancelPlonk}         from "../src/verifiers/BetCancelVerifier.sol";
import {CancelCreditVerifier as CancelCreditPlonk}   from "../src/verifiers/CancelCreditVerifier.sol";

// UltraHonk verifiers (generated by: bb write_vk_ultra_honk + bb contract_ultra_honk)
import {HonkVerifier as BetAuthHonk}             from "../src/verifiers/bet_auth_HonkVerifier.sol";
import {HonkVerifier as SettlementHonk}          from "../src/verifiers/settlement_credit_HonkVerifier.sol";
import {HonkVerifier as WithdrawalHonk}          from "../src/verifiers/withdrawal_HonkVerifier.sol";
import {HonkVerifier as BetCancelHonk}           from "../src/verifiers/bet_cancel_HonkVerifier.sol";
import {HonkVerifier as CancelCreditHonk}        from "../src/verifiers/cancel_credit_HonkVerifier.sol";

/// @notice On-chain verification gas benchmark for all 5 Polyshield ZK circuits.
/// Proofs are loaded from packages/circuits/bench_out/ (generated by bench.sh).
/// Run: cd packages/contracts && forge test --match-contract ZkGasBench --gas-report -vv
contract ZkGasBenchTest is Test {
    // ── Proof paths (relative to foundry.toml = packages/contracts/) ──────────
    string constant BENCH = "../circuits/bench_out/";

    // ── UltraPLONK verifiers ───────────────────────────────────────────────────
    BetAuthPlonk     plonk_bet_auth;
    SettlementPlonk  plonk_settlement;
    WithdrawalPlonk  plonk_withdrawal;
    BetCancelPlonk   plonk_bet_cancel;
    CancelCreditPlonk plonk_cancel_credit;

    // ── UltraHonk verifiers ────────────────────────────────────────────────────
    BetAuthHonk      honk_bet_auth;
    SettlementHonk   honk_settlement;
    WithdrawalHonk   honk_withdrawal;
    BetCancelHonk    honk_bet_cancel;
    CancelCreditHonk honk_cancel_credit;

    function setUp() public {
        plonk_bet_auth      = new BetAuthPlonk();
        plonk_settlement    = new SettlementPlonk();
        plonk_withdrawal    = new WithdrawalPlonk();
        plonk_bet_cancel    = new BetCancelPlonk();
        plonk_cancel_credit = new CancelCreditPlonk();

        honk_bet_auth       = new BetAuthHonk();
        honk_settlement     = new SettlementHonk();
        honk_withdrawal     = new WithdrawalHonk();
        honk_bet_cancel     = new BetCancelHonk();
        honk_cancel_credit  = new CancelCreditHonk();
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    /// Strip the leading N*32 public-input bytes that bb prove prepends to the raw proof.
    /// The Solidity verifiers receive public inputs separately and don't want them in the proof bytes.
    function _stripPubInputs(bytes memory proof, uint256 n) internal pure returns (bytes memory) {
        uint256 skip = n * 32;
        bytes memory stripped = new bytes(proof.length - skip);
        for (uint256 i = 0; i < stripped.length; i++) {
            stripped[i] = proof[skip + i];
        }
        return stripped;
    }

    /// Reformat a bb prove_ultra_honk proof for the Solidity HonkVerifier.
    /// bb format: [4-byte count][3×32 scalars][n×32 pub inputs][curve point elements]
    /// Verifier expects: [3×32 scalars][curve point elements]  (pub inputs passed separately)
    function _reformatHonkProof(bytes memory raw, uint256 n) internal pure returns (bytes memory) {
        uint256 curveStart = 4 + 3 * 32 + n * 32;
        uint256 outLen = 3 * 32 + (raw.length - curveStart);
        bytes memory out = new bytes(outLen);
        // Copy 3 scalar header elements (already right-justified big-endian)
        for (uint256 i = 0; i < 3 * 32; i++) {
            out[i] = raw[4 + i];
        }
        // Copy curve point elements
        for (uint256 i = 0; i < raw.length - curveStart; i++) {
            out[3 * 32 + i] = raw[curveStart + i];
        }
        return out;
    }

    // ── Public input builders ─────────────────────────────────────────────────

    function _betAuthInputs() internal pure returns (bytes32[] memory pi) {
        pi = new bytes32[](9);
        pi[0] = 0x12849593c2e266fc89afced387e8c2d7d3f68a48f342613e37ad673bebcb6dff; // merkle_root
        pi[1] = 0x08fb15898b5e4c6b8c1ee35eff746c62fc2f2c64c777e78640ece1f70a326d58; // nullifier
        pi[2] = 0x0a08b1bf4f86302f3e82727ae3734deeb823c926dca360f713a20f9d88489841; // new_commitment
        pi[3] = bytes32(uint256(100_000_000)); // bet_amount
        pi[4] = bytes32(uint256(65_000_000));  // price
        pi[5] = bytes32(uint256(153_846_153)); // expected_shares
        pi[6] = bytes32(uint256(1));           // market_id
        pi[7] = bytes32(uint256(1));           // outcome_side
        pi[8] = bytes32(uint256(2));           // position_id
    }

    function _settlementInputs() internal pure returns (bytes32[] memory pi) {
        pi = new bytes32[](8);
        pi[0] = 0x2e07f933208147fd5f90a3ac8a5ca9bd7dcfed55d694644e2563b84f4cf2e629; // merkle_root
        pi[1] = 0x2da132475763e195462742943b96e5adeef9ff2145c7fce17fff7cd5a12b1de7; // nullifier
        pi[2] = 0x2b411a7c72ac75c2bbd5a33226124a56581646b0ac32dd85dd5bcc39bf0eb50e; // new_commitment
        pi[3] = bytes32(uint256(1));           // nullifier_of_bet
        pi[4] = bytes32(uint256(1));           // market_id
        pi[5] = bytes32(uint256(500_000));     // payout_per_share
        pi[6] = bytes32(uint256(1_000));       // shares_held
        pi[7] = bytes32(uint256(500_000_000)); // total_credit
    }

    function _withdrawalInputs() internal pure returns (bytes32[] memory pi) {
        pi = new bytes32[](4);
        pi[0] = 0x1b38e33ad3830862fe909db817c8019f9e1ca123f3c37c7b4afb567981d8452e; // merkle_root
        pi[1] = 0x09c55b0e41eaa0641a2f0b617c5cf68ee8cbab08d7d1b8c383f94370bc45cd06; // nullifier
        pi[2] = bytes32(uint256(2_000_000_000)); // withdrawal_amount
        pi[3] = 0x2a7f8171e79cccda7438224cc2c3c679313b42e61bd1db084886b5db5d021210; // recipient_hash
    }

    function _betCancelInputs() internal pure returns (bytes32[] memory pi) {
        pi = new bytes32[](5);
        pi[0] = 0x2446fb0c320269bb0ef1d068eeac847dea30430c83b95b4d3e6a0bd57fabbcdd; // merkle_root
        pi[1] = 0x2505c48fc33a4a2640116427488846b0b55d3f1e9c4c800576aa531a0e83fccc; // nullifier
        pi[2] = 0x18a5090aedfc13b37cc4872ed00640367d36e6fd5b43a977ab464dcc69cd67cf; // new_commitment
        pi[3] = bytes32(uint256(1));           // nullifier_of_bet
        pi[4] = bytes32(uint256(100_000_000)); // bet_amount
    }

    function _cancelCreditInputs() internal pure returns (bytes32[] memory pi) {
        pi = new bytes32[](6);
        pi[0] = 0x12a9891ff42bc23480258c76b6e8e78c8dfe93752d61286c5c1f0500a4aeea6c; // merkle_root
        pi[1] = 0x1d071bf85911ed57ddc6ee4c71a3944b0352d3255ef939ed295e6c928e3e9779; // nullifier
        pi[2] = 0x0863d8d1e258a13ca3203cc47eb385706d122e11cf54469b4f8d631163b78d81; // new_commitment
        pi[3] = bytes32(uint256(2));           // nullifier_of_bet
        pi[4] = bytes32(uint256(12345));       // market_id
        pi[5] = bytes32(uint256(300_000_000)); // bet_amount
    }

    // ── UltraPLONK gas tests ──────────────────────────────────────────────────
    // bb prove prepends N*32 public-input bytes; strip them before passing to the verifier.

    function test_gasBench_PLONK_betAuth() public {
        bytes memory proof = _stripPubInputs(
            vm.readFileBinary(string.concat(BENCH, "bet_auth_plonk_5.proof")), 9);
        bool ok = plonk_bet_auth.verify(proof, _betAuthInputs());
        assertTrue(ok, "PLONK bet_auth verify failed");
    }

    function test_gasBench_PLONK_settlement() public {
        bytes memory proof = _stripPubInputs(
            vm.readFileBinary(string.concat(BENCH, "settlement_credit_plonk_5.proof")), 8);
        bool ok = plonk_settlement.verify(proof, _settlementInputs());
        assertTrue(ok, "PLONK settlement_credit verify failed");
    }

    function test_gasBench_PLONK_withdrawal() public {
        bytes memory proof = _stripPubInputs(
            vm.readFileBinary(string.concat(BENCH, "withdrawal_plonk_5.proof")), 4);
        bool ok = plonk_withdrawal.verify(proof, _withdrawalInputs());
        assertTrue(ok, "PLONK withdrawal verify failed");
    }

    function test_gasBench_PLONK_betCancel() public {
        bytes memory proof = _stripPubInputs(
            vm.readFileBinary(string.concat(BENCH, "bet_cancel_plonk_5.proof")), 5);
        bool ok = plonk_bet_cancel.verify(proof, _betCancelInputs());
