        bool ok = plonk_cancel_credit.verify(proof, _cancelCreditInputs());
        assertTrue(ok, "PLONK cancel_credit verify failed");
    }

    // ── UltraHonk gas tests ───────────────────────────────────────────────────

    function test_gasBench_Honk_betAuth() public {
        bytes memory proof = _reformatHonkProof(
            vm.readFileBinary(string.concat(BENCH, "bet_auth_honk_5.proof")), 9);
        bool ok = honk_bet_auth.verify(proof, _betAuthInputs());
        assertTrue(ok, "Honk bet_auth verify failed");
    }

    function test_gasBench_Honk_settlement() public {
        bytes memory proof = _reformatHonkProof(
            vm.readFileBinary(string.concat(BENCH, "settlement_credit_honk_5.proof")), 8);
        bool ok = honk_settlement.verify(proof, _settlementInputs());
