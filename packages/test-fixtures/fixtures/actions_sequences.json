        "outcome": "success",
        "attackVector": "none",
        "description": "Bet $500 at 0.52 on balanced market — valid proof, valid root, new nullifier",
        "params": {
          "betAmount": "500000000",
          "price": "52000000",
          "expectedShares": "961538461",
          "merkleRootIndex": 0
        }
      },
      {
        "id": "atk_bet_nullifier_replay",
        "type": "authorize_bet",
        "actorId": "adv_zk_replay_nullifier",
        "marketId": "0x0101010101010101010101010101010101010101010101010101010101010101",
        "outcome": "revert_with",
        "revertReason": "NullifierSpent",
        "attackVector": "nullifier_replay",
        "description": "Replay same bet proof twice — second must revert NullifierSpent",
        "params": {
          "nullifier": "0xdeaddeaddeaddeaddeaddeaddeaddeaddeaddeaddeaddeaddeaddeaddeaddead",
          "betAmount": "100000000",
          "price": "50000000",
          "expectedShares": "200000000",
          "attempt": 2
        }
      }
    ],
    "expectedFinalState": "Second bet reverts NullifierSpent; first bet is still active"
  },
