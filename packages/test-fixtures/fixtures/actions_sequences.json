  {
    "id": "seq_nullifier_replay_full",
    "description": "Full nullifier replay: deposit → bet → try to bet again with same nullifier",
    "attackVector": "nullifier_replay",
    "steps": [
      {
        "id": "hp_deposit_small",
        "type": "deposit",
        "actorId": "user_dust_01",
