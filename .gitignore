# Next.js build cache
packages/frontend/.next/
packages/frontend/node_modules/
packages/frontend/design-system/

# Frontend API route handlers — PolyShield does not publish a public API. These server
# routes document the (otherwise loopback-only) backend surface, so they are kept LOCALLY
# for builds but never tracked on GitHub. NOTE: a fresh `git clone` will NOT contain these;
# build/deploy from a working tree that has them on disk (see deploy runbook).
packages/frontend/src/app/api/

# Proving keys — large binary files, regenerate via pnpm circuits:deploy
packages/frontend/public/zkeys/
# Circuit WASM files — regenerate via pnpm circuits:deploy
packages/frontend/public/circuits/*.wasm

# Key material — defensive belt-and-suspenders so no private key/keystore is ever committed
*.pem
*.keystore
*keystore*.json
*-private.json
*.secret

# Misc
.DS_Store
*.log

# Session logs (generated by pnpm dev:mock and frontend logger)
logs/

# Foundry broadcast dev-run files (timestamped; only run-latest.json is kept)
packages/contracts/broadcast/**/run-[0-9]*.json

# Circuit benchmarking outputs
packages/circuits/bench_out/

# SQLite databases (runtime state — regenerated by services, never commit)
packages/backend/*.db
packages/backend/*.db-shm
packages/backend/*.db-wal
packages/backend/indexer/data/
packages/backend/data/

